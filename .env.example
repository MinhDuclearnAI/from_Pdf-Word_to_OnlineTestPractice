############################################
# .env — Root config dùng chung cho docker-compose
# Copy file này thành .env (bỏ .example) và điền giá trị thật trước khi chạy
# TUYỆT ĐỐI KHÔNG commit file .env thật (chỉ commit .env.example) lên Git
############################################

# ============ ENVIRONMENT ============
ENVIRONMENT=development            # development | staging | production
DEBUG=true

# ============ POSTGRESQL ============
POSTGRES_USER=exam_user
POSTGRES_PASSWORD=exam_pass
POSTGRES_DB=exam_db
POSTGRES_HOST=postgres             # tên service trong docker-compose, KHÔNG phải localhost
POSTGRES_PORT=5432

# Backend đọc biến này (ghép từ các biến trên, hoặc set thẳng)
DATABASE_URL=postgresql+psycopg2://exam_user:exam_pass@postgres:5432/exam_db

# Dùng riêng khi chạy test, tránh ghi đè DB dev
DATABASE_URL_TEST=postgresql+psycopg2://exam_user:exam_pass@postgres:5432/exam_test_db

# ============ REDIS (cache, session, Celery broker) ============
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Celery dùng Redis làm broker và backend lưu kết quả task
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============ MINIO / S3 STORAGE ============
S3_ENDPOINT_URL=http://minio:9000              # dùng nội bộ giữa các container Docker
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000   # dùng khi tạo presigned URL trả về cho browser
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=exam-uploads
S3_REGION=us-east-1                            # MinIO không dùng thật nhưng SDK boto3 bắt buộc phải có giá trị
S3_USE_SSL=false                                # true nếu deploy production dùng HTTPS

# ============ JWT / AUTH ============
JWT_SECRET=CHANGE_ME_super_long_random_secret_string_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Reset password token hết hạn sau bao lâu (phút)
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# ============ ANTHROPIC / AI ============
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
AI_MODEL_PARSING=claude-sonnet-5        # model dùng để bóc tách đề thi
AI_MODEL_GRADING=claude-sonnet-5        # model dùng để chấm tự luận
AI_MAX_RETRIES=3                        # số lần retry khi LLM trả JSON sai schema
AI_REQUEST_TIMEOUT_SECONDS=60

# ============ EMAIL (gửi email xác thực / quên mật khẩu) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=CHANGE_ME_app_password    # dùng App Password của Gmail, không dùng mật khẩu thường
SMTP_FROM_NAME=AI Exam Platform
SMTP_FROM_EMAIL=no-reply@examplatform.com
SMTP_USE_TLS=true

# ============ CORS / FRONTEND URL ============
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ RATE LIMITING ============
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_FORGOT_PASSWORD_PER_HOUR=3

# ============ FILE UPLOAD LIMITS ============
MAX_UPLOAD_FILE_SIZE_MB=20
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx

############################################
# FRONTEND (Next.js) — biến bắt đầu bằng NEXT_PUBLIC_ mới lộ ra trình duyệt
# Các biến KHÔNG có prefix này chỉ dùng server-side (an toàn hơn để giấu secret)
############################################

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws

# NextAuth (nếu dùng cho social login Gmail OAuth sau này)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_another_random_secret

# OAuth Google (nếu triển khai đăng nhập Gmail như tài liệu gốc đề cập)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME