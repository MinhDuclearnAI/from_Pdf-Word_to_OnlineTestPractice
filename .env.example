############################################
# .env.example — File cấu hình mẫu của hệ thống
# HƯỚNG DẪN: 
# 1. Copy file này thành file có tên là `.env` (bỏ chữ .example đi)
# 2. Điền các giá trị thật của bạn vào file `.env` vừa tạo
# 3. TUYỆT ĐỐI KHÔNG commit file `.env` lên Github để tránh lộ cấu hình mật
############################################

# ==========================================
# 1. CẤU HÌNH MÔI TRƯỜNG CƠ BẢN
# ==========================================
# Xác định môi trường đang chạy (development: dev ở máy cá nhân | production: chạy thực tế trên server)
ENVIRONMENT=development
# Bật chế độ debug để hiện chi tiết lỗi khi code
DEBUG=true

# ==========================================
# 2. CẤU HÌNH CƠ SỞ DỮ LIỆU (POSTGRESQL)
# ==========================================
# Tên đăng nhập vào database
POSTGRES_USER=postgres
# Mật khẩu database
POSTGRES_PASSWORD=postgres
# Tên database của dự án
POSTGRES_DB=exam_platform_db
# Host của DB (nếu chạy bằng Docker Compose thì để là tên của service database, ví dụ: postgres)
# Nếu chạy Backend thuần (không docker) thì để localhost
POSTGRES_SERVER=localhost
# Cổng mặc định của PostgreSQL
POSTGRES_PORT=5432

# Chuỗi kết nối tổng hợp (Backend sẽ dùng chuỗi này để kết nối tới DB bằng SQLAlchemy)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exam_platform_db

# ==========================================
# 3. CẤU HÌNH REDIS & CELERY (Xử lý tác vụ nền)
# ==========================================
# Cấu hình Redis URL dùng để làm Caching và Celery Broker (hàng đợi)
REDIS_URL=redis://localhost:6379/0
# Cấu hình lưu trữ kết quả của Celery
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==========================================
# 4. CẤU HÌNH BẢO MẬT & XÁC THỰC (JWT)
# ==========================================
# [CỰC KỲ QUAN TRỌNG] Khóa bí mật dùng để mã hóa Token đăng nhập. 
# Ở môi trường thật, hãy đổi thành 1 chuỗi random dài và phức tạp.
JWT_SECRET=super-secret-key-for-dev-only-change-it-in-production
# Thuật toán mã hóa Token
JWT_ALGORITHM=HS256
# Thời gian sống của Access Token (phút) - Mặc định 60 phút
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Thời gian sống của Refresh Token (ngày) - Mặc định 7 ngày
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# 5. CẤU HÌNH AI & LLM (OpenAI-compatible)
# ==========================================
# Key của API (OpenAI-compatible)
GEMINI_API_KEY=key_cua_ban
GEMINI_BASE_URL=https://api.vilao.ai/v1

# (Tùy chọn) Nếu bạn muốn code lại hệ thống để dùng OpenAI hoặc Anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Xác định tên model sẽ dùng để xử lý AI.
DEFAULT_EXTRACTION_MODEL=ts/gemini-2.5-flash-lite
DEFAULT_GRADING_MODEL=ts/gemini-2.5-flash-lite

# ==========================================
# 6. CẤU HÌNH LƯU TRỮ FILE (S3 / MinIO Local)
# ==========================================
# Tài khoản AWS (hoặc MinIO ảo) để truy cập kho lưu trữ
AWS_ACCESS_KEY_ID=minioadmin
# Mật khẩu kho lưu trữ
AWS_SECRET_ACCESS_KEY=minioadmin
# Tên Bucket (thư mục lưu) trên S3/MinIO
AWS_BUCKET_NAME=exam-platform-storage
# Vùng lưu trữ (Mặc định AWS thường là ap-southeast-1, nếu dùng MinIO thì có thể bỏ qua)
AWS_REGION=ap-southeast-1
# Link của dịch vụ MinIO nội bộ (Dùng khi test local thay vì mua thật AWS S3)
S3_ENDPOINT_URL=http://localhost:9000

# ==========================================
# 7. CẤU HÌNH FRONTEND (NEXT.JS)
# Các biến dành cho Frontend (phải bắt đầu bằng NEXT_PUBLIC_ mới lộ ra trình duyệt)
# ==========================================
# URL gốc để gọi API (trỏ tới Backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# (Cấu hình riêng của backend) Danh sách các domain frontend được phép gọi API
BACKEND_CORS_ORIGINS=["http://localhost:3000"]